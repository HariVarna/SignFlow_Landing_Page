# .env
# This file contains local environment variables for development.
# Create a copy named .env and fill in the actual values.

# Flask
# Run `python -c 'import secrets; print(secrets.token_hex(16))'` to generate a secret key
FLASK_SECRET_KEY=your_secret_key_here
FLASK_DEBUG=1

# Google OAuth
# Get these from the Google Cloud Console (https://console.cloud.google.com/)
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# The redirection URI configured in your Google project must match this:
# http://127.0.0.1:5000/auth/google/callback
